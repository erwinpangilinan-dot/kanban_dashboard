# Database (used by api service in Docker; override for local dev)
DATABASE_URL=postgresql://kanban:kanban@localhost:5432/mission_control

# Backend
PORT=3001
NODE_ENV=development
MIGRATIONS_DIR=

# Auth (optional — set JWT_SECRET to enable; API/MCP use AUTH_API_TOKEN)
JWT_SECRET=
AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_API_TOKEN=

# MCP (Cursor agent → Mission Control API)
# Production is source of truth for status; local Docker is dev-only (separate DB).
MISSION_CONTROL_API_URL=http://10.10.50.6/api
# MISSION_CONTROL_API_TOKEN defaults to AUTH_API_TOKEN in mcp/run.sh

# Frontend (Vite dev server only)
VITE_API_URL=http://localhost:3001

# ── Sprint 2: Telegram (Done + overdue + urgent only) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_ON=completed,overdue,urgent
TELEGRAM_OVERDUE_CHECK_HOURS=24

# ── Sprint 2: Email daily digest ──
# Gmail API (preferred when GOOGLE_REFRESH_TOKEN is set) or SMTP fallback
GOOGLE_REFRESH_TOKEN=
GOOGLE_SEND_AS=
EMAIL_FROM=
EMAIL_TO=
EMAIL_DIGEST_CRON="0 8 * * 1-5"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Google Workspace MCP (Cursor agent Gmail/Calendar/Drive) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Sprint 3: GitHub (manual link + auto-create issues) ──
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_REPO=your-org/your-repo
GITHUB_AUTO_CREATE=true
MISSION_CONTROL_PUBLIC_URL=http://localhost
