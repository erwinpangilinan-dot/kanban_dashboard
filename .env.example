# Database (used by api service in Docker; override for local dev)
DATABASE_URL=postgresql://kanban:kanban@localhost:5432/mission_control

# Backend
PORT=3001
NODE_ENV=development
MIGRATIONS_DIR=

# Auth (optional — set JWT_SECRET to enable; API/MCP use AUTH_API_TOKEN)
JWT_SECRET=
AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_API_TOKEN=

# Frontend (Vite dev server only)
VITE_API_URL=http://localhost:3001

# ── Sprint 3: Slack (Done + overdue + urgent only) ──
SLACK_WEBHOOK_URL=
SLACK_NOTIFY_ON=completed,overdue,urgent

# ── Sprint 3: Email (daily digest only) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=mission-control@localhost
EMAIL_TO=team@localhost
EMAIL_DIGEST_CRON=0 8 * * 1-5

# ── Sprint 4: GitHub (manual link + auto-create issues) ──
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_REPO=your-org/your-repo
