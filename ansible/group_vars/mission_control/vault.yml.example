# Copy to vault.yml, fill in values, then encrypt:
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml
#
# Or pass at deploy time: ansible-playbook ... -e @secrets.yml

mc_postgres_password: "change-me-long-random"
mc_jwt_secret: "change-me-long-random"
mc_auth_password: "change-me-long-random"
mc_auth_api_token: "change-me-long-random"

# Optional
mc_telegram_bot_token: ""
mc_telegram_chat_id: ""
mc_email_from: ""
mc_email_to: ""
mc_google_client_id: ""
mc_google_client_secret: ""
mc_google_refresh_token: ""
mc_google_send_as: ""

# Sprint 3: GitHub integration
mc_github_token: ""
mc_github_webhook_secret: ""
mc_github_default_repo: "erwinpangilinan-dot/kanban_dashboard"
mc_github_auto_create: "true"

# Production URL (used in GitHub issue links and ops checks)
mc_public_url: "http://10.10.50.6"

# Optional TLS (self-signed cert for LAN HTTPS)
mc_enable_tls: false
mc_tls_port: 443
mc_tls_cn: "10.10.50.6"
