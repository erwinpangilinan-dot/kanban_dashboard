# Managed by Ansible — do not edit on server
DATABASE_URL=postgresql://{{ mc_postgres_user }}:{{ mc_postgres_password }}@postgres:5432/{{ mc_postgres_db }}

PORT=3001
NODE_ENV=production
MIGRATIONS_DIR=/app/database/migrations

JWT_SECRET={{ mc_jwt_secret }}
AUTH_USERNAME={{ mc_auth_username }}
AUTH_PASSWORD={{ mc_auth_password }}
AUTH_API_TOKEN={{ mc_auth_api_token }}

TELEGRAM_BOT_TOKEN={{ mc_telegram_bot_token }}
