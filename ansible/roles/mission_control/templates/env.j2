TELEGRAM_NOTIFY_ON={{ mc_telegram_notify_on }}
TELEGRAM_OVERDUE_CHECK_HOURS={{ mc_telegram_overdue_check_hours }}

EMAIL_FROM={{ mc_email_from }}
