GOOGLE_REFRESH_TOKEN={{ mc_google_refresh_token }}
GOOGLE_SEND_AS={{ mc_google_send_as }}

OLLAMA_BASE_URL={{ mc_ollama_base_url }}
OLLAMA_MODEL={{ mc_ollama_model }}
OLLAMA_TIMEOUT_MS={{ mc_ollama_timeout_ms }}

GITHUB_TOKEN={{ mc_github_token }}
GITHUB_WEBHOOK_SECRET={{ mc_github_webhook_secret }}
